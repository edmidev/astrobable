---
interface Props {
  titulo?: string;
  embedUrl: string;
  altura?: "sm" | "md" | "lg";
}

const { titulo, embedUrl, altura = "md" } = Astro.props;

if (!embedUrl) return;

const heightClass = {
  sm: "h-[300px]",
  md: "h-[400px]",
  lg: "h-[500px]",
}[altura];
---

<section class="py-20 md:py-28 bg-gray-50" id="ubicacion">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {titulo && (
      <div class="text-center mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900">{titulo}</h2>
      </div>
    )}
    
    <div class={`w-full ${heightClass} rounded-2xl overflow-hidden shadow-lg border border-gray-200 bg-gray-300 relative`}>
      <iframe 
        src={embedUrl} 
        width="100%" 
        height="100%" 
        style="border:0;" 
        allowfullscreen="" 
        loading="lazy" 
        referrerpolicy="no-referrer-when-downgrade"
        class="absolute inset-0"
        title="Mapa de ubicación"
      ></iframe>
    </div>
  </div>
</section>
