---
interface Props {
  titulo?: string;
  embedUrl: string;
  altura?: "sm" | "md" | "lg";
}

const { titulo, embedUrl, altura = "md" } = Astro.props;

if (!embedUrl) return;

const heightClass = {
  sm: "h-[300px]",
  md: "h-[400px]",
  lg: "h-[500px]",
}[altura];
---

<section class="py-24 md:py-32 bg-[var(--surface-container-low)]" id="ubicacion">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {titulo && (
      <div class="text-center mb-12">
        <h2 class="section-title">{titulo}</h2>
      </div>
    )}
    
    <div class={`w-full ${heightClass} rounded-2xl md:rounded-3xl overflow-hidden shadow-[var(--shadow-ambient)] bg-[var(--surface-container-high)] relative transition-all duration-500 hover:shadow-[var(--shadow-float)]`}>
      <iframe 
        src={embedUrl} 
        width="100%" 
        height="100%" 
        style="border:0;" 
        allowfullscreen="" 
        loading="lazy" 
        referrerpolicy="no-referrer-when-downgrade"
        class="absolute inset-0 grayscale contrast-[1.1] brightness-[0.9] hover:grayscale-0 transition-all duration-700"
        title="Mapa de ubicación"
      ></iframe>
    </div>
  </div>
</section>
