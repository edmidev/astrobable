---
interface Props {
  titulo: string;
  subtitulo: string;
  cta: { texto: string; enlace: string };
  ctaSecundario?: { texto: string; enlace: string };
  imagen?: string;
  estilo?: "centrado" | "gradiente" | "imagen-fondo";
}

const { 
  titulo, 
  subtitulo, 
  cta, 
  ctaSecundario, 
  imagen, 
  estilo = "centrado" 
} = Astro.props;

// Clases condicionales basadas en el estilo
const isGradient = estilo === "gradiente";
const isImageBg = estilo === "imagen-fondo";

const bgClass = isImageBg 
  ? "bg-[var(--tertiary)] overflow-hidden relative" 
  : isGradient
    ? "hero-gradient-animated"
    : "bg-[var(--surface)]";

const textClass = (isImageBg || isGradient) ? "text-white" : "text-[var(--on-surface)]";
const subTextClass = (isImageBg || isGradient) ? "text-white/70" : "text-[var(--on-surface-variant)]";
---

<section class={`min-h-[85vh] md:min-h-[90vh] py-24 md:py-40 flex items-center justify-center relative overflow-hidden ${bgClass}`}>
  
  {isGradient && (
    <div class="absolute inset-0 opacity-40 pointer-events-none">
      <div class="absolute top-0 left-0 w-full h-full bg-[radial-gradient(circle_at_20%_30%,rgba(118,113,255,0.15)_0%,transparent_50%)]"></div>
      <div class="absolute bottom-0 right-0 w-full h-full bg-[radial-gradient(circle_at_80%_70%,rgba(55,48,217,0.15)_0%,transparent_50%)]"></div>
    </div>
  )}

  {isImageBg && imagen && (
    <div class="absolute inset-0 z-0">
      <img src={imagen} alt="Fondo" class="w-full h-full object-cover opacity-20 mix-blend-overlay" />
    </div>
  )}

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full text-center">
    <div class="max-w-5xl mx-auto">
      <h1 class={`reveal delay-100 max-w-4xl mx-auto text-5xl md:text-7xl lg:text-8xl font-extrabold leading-[1.05] mb-10 tracking-[-0.04em] ${textClass}`}>
        {titulo}
      </h1>
      
      <p class={`reveal delay-300 max-w-2xl mx-auto text-xl md:text-2xl leading-relaxed mb-14 font-medium ${subTextClass}`}>
        {subtitulo}
      </p>
      
      <div class="reveal delay-500 flex flex-col sm:flex-row items-center justify-center gap-8">
        <a 
          href={cta.enlace} 
          class="btn-primary w-full sm:w-auto text-xl px-12 py-5 rounded-2xl shadow-2xl"
        >
          {cta.texto}
        </a>
        
        {ctaSecundario && (
          <a 
            href={ctaSecundario.enlace} 
            class={`btn-secondary w-full sm:w-auto text-xl px-12 py-5 rounded-2xl border border-white/10 ${
              (isImageBg || isGradient) 
                ? "bg-white/5 text-white hover:bg-white/10 backdrop-blur-sm shadow-xl" 
                : "bg-[var(--surface-container-high)]"
            }`}
          >
            {ctaSecundario.texto}
          </a>
        )}
      </div>
    </div>
  </div>
</section>
