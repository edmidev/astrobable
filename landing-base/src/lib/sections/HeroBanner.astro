---
interface Props {
  titulo: string;
  subtitulo: string;
  cta: { texto: string; enlace: string };
  ctaSecundario?: { texto: string; enlace: string };
  imagen?: string;
  estilo?: "centrado" | "gradiente" | "imagen-fondo";
}

const { 
  titulo, 
  subtitulo, 
  cta, 
  ctaSecundario, 
  imagen, 
  estilo = "centrado" 
} = Astro.props;

// Clases condicionales basadas en el estilo
const isGradient = estilo === "gradiente";
const isImageBg = estilo === "imagen-fondo";

const bgClass = isImageBg 
  ? "bg-gray-900 overflow-hidden relative" 
  : isGradient
    ? "bg-gradient-to-br from-blue-50 to-white"
    : "bg-white";

const textClass = isImageBg ? "text-white" : "text-gray-900";
const subTextClass = isImageBg ? "text-gray-300" : "text-gray-600";
---

<section class={`min-h-[70vh] md:min-h-[85vh] py-20 md:py-32 flex items-center justify-center ${bgClass}`}>
  
  {isImageBg && imagen && (
    <div class="absolute inset-0 z-0">
      <img src={imagen} alt="Fondo" class="w-full h-full object-cover opacity-40 mix-blend-overlay" />
    </div>
  )}

  {isImageBg && !imagen && (
    <div class="absolute inset-0 z-0 bg-blue-900 opacity-80"></div>
  )}

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full text-center">
    <div class="max-w-4xl mx-auto">
      <h1 class={`max-w-3xl mx-auto text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6 ${textClass}`}>
        {titulo}
      </h1>
      
      <p class={`max-w-2xl mx-auto text-base md:text-lg leading-relaxed mb-10 ${subTextClass}`}>
        {subtitulo}
      </p>
      
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a 
          href={cta.enlace} 
          class="w-full sm:w-auto bg-blue-600 text-white px-8 py-4 rounded-lg text-lg font-medium hover:bg-blue-700 transition-colors shadow-md hover:shadow-lg focus:ring-2 focus:ring-blue-600 focus:ring-offset-2"
        >
          {cta.texto}
        </a>
        
        {ctaSecundario && (
          <a 
            href={ctaSecundario.enlace} 
            class={`w-full sm:w-auto px-8 py-4 rounded-lg text-lg font-medium transition-colors border-2 focus:ring-2 focus:ring-offset-2 ${
              isImageBg 
                ? "border-white/30 text-white hover:bg-white/10 focus:ring-white" 
                : "border-blue-600 text-blue-600 hover:bg-blue-50 focus:ring-blue-600"
            }`}
          >
            {ctaSecundario.texto}
          </a>
        )}
      </div>
    </div>
  </div>
</section>
