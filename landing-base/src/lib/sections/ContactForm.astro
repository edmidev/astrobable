---
import { Icon } from 'astro-icon/components';

interface ContactInfo {
  telefono?: string;
  email?: string;
  whatsapp?: string;
  direccion?: string;
  horario?: string;
}

interface Props {
  titulo?: string;
  campos?: string[];
  info: ContactInfo;
  layout?: "split" | "centrado";
}

const { 
  titulo = "Hablemos", 
  campos = ["nombre", "email", "telefono", "mensaje"], 
  info, 
  layout = "split" 
} = Astro.props;

const showPhone = info.telefono;
const showEmail = info.email;
const showAddress = info.direccion;
const showSchedule = info.horario;

const FormHTML = `
  <form class="space-y-6" onsubmit="event.preventDefault();">
    <!-- TODO: Conectar backend -->
    ${campos.includes("nombre") ? `
      <div>
        <label for="nombre" class="block text-sm font-medium text-gray-700 mb-1">Nombre completo</label>
        <input type="text" id="nombre" name="nombre" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-600 focus:border-blue-600 transition-colors" placeholder="Tu nombre" required>
      </div>
    ` : ''}
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      ${campos.includes("email") ? `
        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
          <input type="email" id="email" name="email" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-600 focus:border-blue-600 transition-colors" placeholder="tu@email.com" required>
        </div>
      ` : ''}
      
      ${campos.includes("telefono") ? `
        <div>
          <label for="telefono" class="block text-sm font-medium text-gray-700 mb-1">Teléfono</label>
          <input type="tel" id="telefono" name="telefono" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-600 focus:border-blue-600 transition-colors" placeholder="+1 234 567 890">
        </div>
      ` : ''}
    </div>
    
    ${campos.includes("mensaje") ? `
      <div>
        <label for="mensaje" class="block text-sm font-medium text-gray-700 mb-1">Mensaje</label>
        <textarea id="mensaje" name="mensaje" rows="4" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-600 focus:border-blue-600 transition-colors" placeholder="¿En qué te podemos ayudar?" required></textarea>
      </div>
    ` : ''}
    
    <button type="submit" class="w-full bg-blue-600 text-white font-semibold py-4 rounded-lg hover:bg-blue-700 transition-colors shadow-md">
      Enviar Mensaje
    </button>
    
    ${info.whatsapp ? `
      <div class="mt-4 text-center">
        <p class="text-sm text-gray-500 mb-2">O escríbenos directo por WhatsApp</p>
        <a href="https://wa.me/${info.whatsapp.replace(/\\D/g, "")}" target="_blank" class="inline-flex items-center justify-center gap-2 w-full border-2 border-green-500 text-green-600 font-semibold py-3 rounded-lg hover:bg-green-50 transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
          Chatear por WhatsApp
        </a>
      </div>
    ` : ''}
  </form>
`;
---

<section class="py-24 md:py-32 bg-white" id="contacto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 md:mb-16">
      <h2 class="max-w-2xl mx-auto text-3xl md:text-4xl font-bold text-gray-900">{titulo}</h2>
    </div>

    {layout === "split" ? (
      <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">
        <!-- Formulario -->
        <div class="bg-white rounded-2xl p-8 border border-gray-100 shadow-xl">
          <h3 class="text-2xl font-bold text-gray-900 mb-6">Envíanos un mensaje</h3>
          <div set:html={FormHTML} />
        </div>
        
        <!-- Info de contacto -->
        <div class="flex flex-col justify-center space-y-8">
          <div>
            <h3 class="text-2xl font-bold text-gray-900 mb-6">Información de contacto</h3>
            <p class="text-gray-600 mb-8 leading-relaxed">
              Estamos acá para ayudarte. Podés comunicarte con nosotros usando estos medios o directamente rellenando el formulario.
            </p>
          </div>
          
          <div class="space-y-6">
            {showPhone && (
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-full bg-blue-50 flex items-center justify-center text-blue-600 shrink-0">
                  <Icon name="lucide:phone" class="w-6 h-6" />
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900">Teléfono</h4>
                  <p class="text-gray-600 mt-1">{info.telefono}</p>
                </div>
              </div>
            )}
            
            {showEmail && (
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-full bg-blue-50 flex items-center justify-center text-blue-600 shrink-0">
                  <Icon name="lucide:mail" class="w-6 h-6" />
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900">Email</h4>
                  <a href={`mailto:${info.email}`} class="text-blue-600 hover:underline mt-1 block">{info.email}</a>
                </div>
              </div>
            )}
            
            {showAddress && (
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-full bg-blue-50 flex items-center justify-center text-blue-600 shrink-0">
                  <Icon name="lucide:map-pin" class="w-6 h-6" />
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900">Dirección</h4>
                  <p class="text-gray-600 mt-1">{info.direccion}</p>
                </div>
              </div>
            )}
            
            {showSchedule && (
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-full bg-blue-50 flex items-center justify-center text-blue-600 shrink-0">
                  <Icon name="lucide:clock" class="w-6 h-6" />
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900">Horario de atención</h4>
                  <p class="text-gray-600 mt-1">{info.horario}</p>
                </div>
              </div>
            )}
          </div>
        </div>
      </div>
    ) : (
      <!-- Formulario Centrado -->
      <div class="max-w-2xl mx-auto bg-white rounded-2xl p-8 border border-gray-100 shadow-xl">
        <h3 class="text-2xl font-bold text-gray-900 mb-8 text-center">Te respondemos en breve</h3>
        <div set:html={FormHTML} />
      </div>
    )}
  </div>
</section>
