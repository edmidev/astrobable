---
import { Icon } from 'astro-icon/components';

interface ContactInfo {
  telefono?: string;
  email?: string;
  whatsapp?: string;
  direccion?: string;
  horario?: string;
}

interface Props {
  titulo?: string;
  campos?: string[];
  info: ContactInfo;
  layout?: "split" | "centrado";
}

const { 
  titulo = "Hablemos", 
  campos = ["nombre", "email", "telefono", "mensaje"], 
  info, 
  layout = "split" 
} = Astro.props;

const showPhone = info.telefono;
const showEmail = info.email;
const showAddress = info.direccion;
const showSchedule = info.horario;

const FormHTML = `
  <form class="space-y-6" onsubmit="event.preventDefault();">
    ${campos.includes("nombre") ? `
      <div>
        <label for="nombre" class="block text-sm font-bold text-[var(--on-surface)] mb-2 uppercase tracking-wide">Nombre completo</label>
        <input type="text" id="nombre" name="nombre" class="w-full px-5 py-4 rounded-xl bg-[var(--surface-container-low)] border-0 text-[var(--on-surface)] focus:ring-2 focus:ring-[var(--primary)] transition-all placeholder:text-[var(--on-surface-variant)] placeholder:opacity-50" placeholder="Tu nombre" required>
      </div>
    ` : ''}
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      ${campos.includes("email") ? `
        <div>
          <label for="email" class="block text-sm font-bold text-[var(--on-surface)] mb-2 uppercase tracking-wide">Email</label>
          <input type="email" id="email" name="email" class="w-full px-5 py-4 rounded-xl bg-[var(--surface-container-low)] border-0 text-[var(--on-surface)] focus:ring-2 focus:ring-[var(--primary)] transition-all placeholder:text-[var(--on-surface-variant)] placeholder:opacity-50" placeholder="tu@email.com" required>
        </div>
      ` : ''}
      
      ${campos.includes("telefono") ? `
        <div>
          <label for="telefono" class="block text-sm font-bold text-[var(--on-surface)] mb-2 uppercase tracking-wide">Teléfono</label>
          <input type="tel" id="telefono" name="telefono" class="w-full px-5 py-4 rounded-xl bg-[var(--surface-container-low)] border-0 text-[var(--on-surface)] focus:ring-2 focus:ring-[var(--primary)] transition-all placeholder:text-[var(--on-surface-variant)] placeholder:opacity-50" placeholder="+1 234 567 890">
        </div>
      ` : ''}
    </div>
    
    ${campos.includes("mensaje") ? `
      <div>
        <label for="mensaje" class="block text-sm font-bold text-[var(--on-surface)] mb-2 uppercase tracking-wide">Mensaje</label>
        <textarea id="mensaje" name="mensaje" rows="4" class="w-full px-5 py-4 rounded-xl bg-[var(--surface-container-low)] border-0 text-[var(--on-surface)] focus:ring-2 focus:ring-[var(--primary)] transition-all placeholder:text-[var(--on-surface-variant)] placeholder:opacity-50" placeholder="¿En qué te podemos ayudar?" required></textarea>
      </div>
    ` : ''}
    
    <button type="submit" class="btn-primary w-full py-5 text-lg shadow-[var(--shadow-float)]">
      Enviar Mensaje
    </button>
    
    ${info.whatsapp ? `
      <div class="mt-8 text-center">
        <p class="text-sm font-bold text-[var(--on-surface-variant)] mb-4 uppercase tracking-widest opacity-60">O escríbenos directo por WhatsApp</p>
        <a href="https://wa.me/${info.whatsapp.replace(/\D/g, "")}" target="_blank" class="inline-flex items-center justify-center gap-3 w-full bg-[#25D366]/10 text-[#128C7E] font-bold py-4 rounded-xl hover:bg-[#25D366]/20 transition-all border border-[#25D366]/20">
          <Icon name="lucide:message-circle" class="w-6 h-6" />
          Chatear por WhatsApp
        </a>
      </div>
    ` : ''}
  </form>
`;
---

<section class="py-24 md:py-32 bg-[var(--surface)]" id="contacto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-20">
      <h2 class="section-title">{titulo}</h2>
    </div>

    {layout === "split" ? (
      <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24 items-center">
        <!-- Formulario -->
        <div class="bg-[var(--surface-container-lowest)] rounded-3xl p-8 md:p-12 shadow-[var(--shadow-ambient)] border border-[rgba(198,198,205,0.15)]">
          <h3 class="text-3xl font-extrabold text-[var(--on-surface)] mb-8 tracking-tight">Envíanos un mensaje</h3>
          <div set:html={FormHTML} />
        </div>
        
        <!-- Info de contacto -->
        <div class="flex flex-col justify-center space-y-12">
          <div>
            <h3 class="text-3xl font-extrabold text-[var(--on-surface)] mb-6 tracking-tight">Información de contacto</h3>
            <p class="text-xl text-[var(--on-surface-variant)] mb-8 leading-relaxed font-medium">
              Estamos acá para ayudarte. Podés comunicarte con nosotros usando estos medios o directamente rellenando el formulario.
            </p>
          </div>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
            {showPhone && (
              <div class="flex flex-col gap-4">
                <div class="w-14 h-14 rounded-2xl bg-[var(--surface-container-low)] flex items-center justify-center text-[var(--primary)] shrink-0 shadow-sm">
                  <Icon name="lucide:phone" class="w-7 h-7" />
                </div>
                <div>
                  <h4 class="font-bold text-[var(--on-surface)] text-lg uppercase tracking-wider scale-90 origin-left opacity-40">Teléfono</h4>
                  <p class="text-xl font-bold text-[var(--on-surface)]">{info.telefono}</p>
                </div>
              </div>
            )}
            
            {showEmail && (
              <div class="flex flex-col gap-4">
                <div class="w-14 h-14 rounded-2xl bg-[var(--surface-container-low)] flex items-center justify-center text-[var(--primary)] shrink-0 shadow-sm">
                  <Icon name="lucide:mail" class="w-7 h-7" />
                </div>
                <div>
                  <h4 class="font-bold text-[var(--on-surface)] text-lg uppercase tracking-wider scale-90 origin-left opacity-40">Email</h4>
                  <a href={`mailto:${info.email}`} class="text-xl font-bold text-[var(--primary)] hover:opacity-80 transition-opacity block overflow-hidden text-ellipsis">{info.email}</a>
                </div>
              </div>
            )}
            
            {showAddress && (
              <div class="flex flex-col gap-4">
                <div class="w-14 h-14 rounded-2xl bg-[var(--surface-container-low)] flex items-center justify-center text-[var(--primary)] shrink-0 shadow-sm">
                  <Icon name="lucide:map-pin" class="w-7 h-7" />
                </div>
                <div>
                  <h4 class="font-bold text-[var(--on-surface)] text-lg uppercase tracking-wider scale-90 origin-left opacity-40">Dirección</h4>
                  <p class="text-xl font-bold text-[var(--on-surface)]">{info.direccion}</p>
                </div>
              </div>
            )}
            
            {showSchedule && (
              <div class="flex flex-col gap-4">
                <div class="w-14 h-14 rounded-2xl bg-[var(--surface-container-low)] flex items-center justify-center text-[var(--primary)] shrink-0 shadow-sm">
                  <Icon name="lucide:clock" class="w-7 h-7" />
                </div>
                <div>
                  <h4 class="font-bold text-[var(--on-surface)] text-lg uppercase tracking-wider scale-90 origin-left opacity-40">Horario</h4>
                  <p class="text-xl font-bold text-[var(--on-surface)]">{info.horario}</p>
                </div>
              </div>
            )}
          </div>
        </div>
      </div>
    ) : (
      <!-- Formulario Centrado -->
      <div class="max-w-2xl mx-auto bg-[var(--surface-container-lowest)] rounded-3xl p-8 md:p-12 shadow-[var(--shadow-ambient)] border border-[rgba(198,198,205,0.15)]">
        <h3 class="text-3xl font-extrabold text-[var(--on-surface)] mb-10 text-center tracking-tight">Te respondemos en breve</h3>
        <div set:html={FormHTML} />
      </div>
    )}
  </div>
</section>
