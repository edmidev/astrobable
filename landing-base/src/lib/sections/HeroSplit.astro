---
interface Props {
  titulo: string;
  subtitulo: string;
  cta: { texto: string; enlace: string };
  imagen?: string;
  invertir?: boolean;
}

const { 
  titulo, 
  subtitulo, 
  cta, 
  imagen, 
  invertir = false 
} = Astro.props;
---

<section class="py-24 md:py-40 bg-[var(--surface-container-low)] overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      
      <div class={`max-w-xl ${invertir ? 'lg:order-2 lg:pl-16' : 'lg:order-1'}`}>
        <h1 class="reveal delay-100 text-4xl md:text-6xl font-extrabold text-[var(--on-surface)] leading-[1.1] mb-8 tracking-[-0.03em]">
          {titulo}
        </h1>
        <p class="reveal delay-300 text-lg md:text-xl text-[var(--on-surface-variant)] leading-relaxed mb-12 font-medium">
          {subtitulo}
        </p>
        <a 
          href={cta.enlace}
          class="reveal delay-500 btn-primary px-10 py-5 rounded-2xl text-xl shadow-2xl"
        >
          {cta.texto}
        </a>
      </div>

      <div class={`reveal delay-200 relative w-full aspect-square md:aspect-video lg:aspect-square rounded-3xl overflow-hidden shadow-[var(--shadow-float)] ${invertir ? 'lg:order-1' : 'lg:order-2'}`}>
        {imagen ? (
          <img src={imagen} alt={titulo} class="absolute inset-0 w-full h-full object-cover hover:scale-105 transition-transform duration-1000" loading="lazy" />
        ) : (
          <div class="absolute inset-0 bg-gradient-to-tr from-[var(--surface-container-high)] to-[var(--surface-container-lowest)] flex items-center justify-center">
            <span class="text-[var(--on-surface-variant)] font-medium text-lg opacity-30">Imagen Destacada</span>
          </div>
        )}
      </div>
      
    </div>
  </div>
</section>
