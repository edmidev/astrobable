---
interface Props {
  titulo: string;
  subtitulo: string;
  cta: { texto: string; enlace: string };
  imagen?: string;
  invertir?: boolean;
}

const { 
  titulo, 
  subtitulo, 
  cta, 
  imagen, 
  invertir = false 
} = Astro.props;
---

<section class="py-24 md:py-32 bg-white overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      
      <div class={`max-w-xl ${invertir ? 'lg:order-2 lg:pl-12' : 'lg:order-1'}`}>
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 leading-tight mb-6">
          {titulo}
        </h1>
        <p class="text-lg md:text-xl text-gray-600 leading-relaxed mb-8">
          {subtitulo}
        </p>
        <a 
          href={cta.enlace}
          class="inline-flex items-center justify-center bg-blue-600 text-white font-medium px-8 py-4 rounded-lg text-lg hover:bg-blue-700 transition-colors shadow-md hover:shadow-lg focus:ring-2 focus:ring-blue-600 focus:ring-offset-2"
        >
          {cta.texto}
        </a>
      </div>

      <div class={`relative w-full aspect-square md:aspect-video lg:aspect-square rounded-2xl overflow-hidden shadow-2xl ${invertir ? 'lg:order-1' : 'lg:order-2'}`}>
        {imagen ? (
          <img src={imagen} alt={titulo} class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
        ) : (
          <div class="absolute inset-0 bg-gradient-to-tr from-blue-100 to-blue-50 flex items-center justify-center">
            <span class="text-blue-300 font-medium text-lg">Imagen Destacada</span>
          </div>
        )}
      </div>
      
    </div>
  </div>
</section>
