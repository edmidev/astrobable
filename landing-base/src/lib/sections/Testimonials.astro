---
import { Icon } from 'astro-icon/components';

interface Item {
  nombre: string;
  cargo?: string;
  texto: string;
  avatar?: string;
  estrellas?: number;
}

interface Props {
  titulo?: string;
  items: Item[];
  layout?: "carrusel" | "grid" | "destacado";
}

const { titulo, items, layout = "grid" } = Astro.props;

if (!items || items.length === 0) return;
---

<section class="py-24 md:py-32 bg-[var(--surface)]" id="testimonios">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    {titulo && (
      <div class="text-center mb-16">
        <h2 class="section-title">{titulo}</h2>
      </div>
    )}

    {layout === "grid" && (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
        {items.map(item => (
          <div class="bg-[var(--surface-container-lowest)] rounded-2xl p-8 border border-[rgba(198,198,205,0.15)] shadow-[var(--shadow-ambient)] relative transition-all duration-500 hover:shadow-[var(--shadow-float)]">
            <Icon name="lucide:quote" class="absolute top-6 right-6 w-8 h-8 text-[var(--primary)] opacity-10" />
            
            <div class="flex gap-1 mb-6 text-yellow-400">
              {Array.from({ length: item.estrellas || 5 }).map(() => (
                <Icon name="lucide:star" class="w-5 h-5 fill-current" />
              ))}
            </div>
            
            <p class="text-[var(--on-surface-variant)] italic mb-8 leading-relaxed text-lg">"{item.texto}"</p>
            
            <div class="flex items-center gap-4 mt-auto">
              {item.avatar ? (
                <img src={item.avatar} alt={item.nombre} class="w-12 h-12 rounded-full object-cover shadow-sm grayscale hover:grayscale-0 transition-all" loading="lazy" />
              ) : (
                <div class="w-12 h-12 rounded-2xl bg-[var(--surface-container-low)] text-[var(--primary)] flex items-center justify-center font-bold text-lg shadow-inner">
                  {item.nombre.charAt(0)}
                </div>
              )}
              <div>
                <h4 class="font-bold text-[var(--on-surface)]">{item.nombre}</h4>
                {item.cargo && <p class="text-sm text-[var(--on-surface-variant)] opacity-70">{item.cargo}</p>}
              </div>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>
