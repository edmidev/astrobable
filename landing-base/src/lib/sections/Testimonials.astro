---
import { Icon } from 'astro-icon/components';

interface Item {
  nombre: string;
  cargo?: string;
  texto: string;
  avatar?: string;
  estrellas?: number;
}

interface Props {
  titulo?: string;
  items: Item[];
  layout?: "carrusel" | "grid" | "destacado";
}

const { titulo, items, layout = "grid" } = Astro.props;

if (!items || items.length === 0) return;
---

<section class="py-24 md:py-32 bg-white" id="testimonios">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    {titulo && (
      <div class="text-center mb-12 md:mb-16">
        <h2 class="max-w-2xl mx-auto text-3xl md:text-4xl font-bold text-gray-900">{titulo}</h2>
      </div>
    )}

    {layout === "grid" && (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
        {items.map(item => (
          <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 shadow-sm relative">
            <Icon name="lucide:quote" class="absolute top-6 right-6 w-8 h-8 text-blue-100" />
            
            <div class="flex gap-1 mb-6 text-yellow-400">
              {Array.from({ length: item.estrellas || 5 }).map(() => (
                <Icon name="lucide:star" class="w-5 h-5 fill-current" />
              ))}
            </div>
            
            <p class="text-gray-700 italic mb-8 leading-relaxed">"{item.texto}"</p>
            
            <div class="flex items-center gap-4 mt-auto">
              {item.avatar ? (
                <img src={item.avatar} alt={item.nombre} class="w-12 h-12 rounded-full object-cover shadow-sm bg-gray-200" loading="lazy" />
              ) : (
                <div class="w-12 h-12 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center font-bold text-lg">
                  {item.nombre.charAt(0)}
                </div>
              )}
              <div>
                <h4 class="font-bold text-gray-900">{item.nombre}</h4>
                {item.cargo && <p class="text-sm text-gray-500">{item.cargo}</p>}
              </div>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>
