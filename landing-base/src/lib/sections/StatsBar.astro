---
import { Icon } from 'astro-icon/components';

interface Item {
  valor: string;
  label: string;
  icono?: string;
}

interface Props {
  items: Item[];
  fondo?: "primario" | "oscuro" | "claro";
}

const { items, fondo = "primario" } = Astro.props;

if (!items || items.length === 0) return;

const bgClasses = {
  "primario": "bg-[var(--primary)] text-[var(--on-primary)]",
  "oscuro": "bg-[var(--tertiary)] text-white",
  "claro": "bg-[var(--surface-container-low)] text-[var(--on-surface)]",
};

const textCls = fondo === "claro" ? "text-[var(--primary)]" : "text-white";
const labelCls = fondo === "claro" ? "text-[var(--on-surface-variant)]" : "text-white/70";
const iconBg = fondo === "claro" ? "bg-white shadow-sm" : "bg-white/10";
---

<section class={`py-24 md:py-32 w-full ${bgClasses[fondo]}`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12 text-center">
      
      {items.map(item => (
        <div class="flex flex-col items-center justify-center space-y-2">
          {item.icono && (
            <div class={`w-12 h-12 rounded-full flex items-center justify-center mb-2 ${iconBg}`}>
              <Icon name={`lucide:${item.icono}`} class="w-6 h-6" />
            </div>
          )}
          <span class={`text-4xl md:text-5xl font-bold tracking-tight ${textCls}`}>
            {item.valor}
          </span>
          <span class={`text-sm md:text-base font-medium tracking-wide uppercase ${labelCls}`}>
            {item.label}
          </span>
        </div>
      ))}
      
    </div>
  </div>
</section>
