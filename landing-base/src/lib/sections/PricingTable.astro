---
import { Icon } from 'astro-icon/components';

interface Plan {
  nombre: string;
  precio: string;
  periodo?: string;
  descripcion?: string;
  caracteristicas: string[];
  destacado: boolean;
  cta: { texto: string; enlace: string };
}

interface Props {
  titulo: string;
  subtitulo?: string;
  items: Plan[];
}

const { titulo, subtitulo, items } = Astro.props;

if (!items || items.length === 0) return;
---

<section class="py-24 md:py-32 bg-[var(--surface-container-low)]" id="precios">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="section-title mb-4">{titulo}</h2>
      {subtitulo && <p class="section-subtitle">{subtitulo}</p>}
    </div>

    <div class="flex flex-col lg:flex-row flex-wrap justify-center gap-8 items-center lg:items-stretch">
      {items.map(plan => (
        <div class={`relative flex flex-col w-full max-w-sm rounded-[var(--radius-lg)] bg-[var(--surface-container-lowest)] shadow-[var(--shadow-ambient)] flex-1 min-w-[300px] transition-all duration-500 hover:shadow-[var(--shadow-float)] ${plan.destacado ? 'ring-2 ring-[var(--primary)] scale-100 lg:scale-105 z-10' : 'border border-[rgba(198,198,205,0.15)]'}`}>
          
          {plan.destacado && (
            <div class="absolute top-0 inset-x-0 flex justify-center -translate-y-1/2">
              <span class="bg-[var(--primary)] text-white text-sm font-bold uppercase tracking-widest py-1.5 px-6 rounded-full shadow-lg">
                Más Popular
              </span>
            </div>
          )}

          <div class="p-10 pb-0">
            <h3 class="text-2xl font-bold text-[var(--on-surface)]">{plan.nombre}</h3>
            {plan.descripcion && <p class="text-sm text-[var(--on-surface-variant)] mt-2 font-medium">{plan.descripcion}</p>}
            
            <div class="mt-8 flex items-baseline gap-1">
              <span class="text-5xl font-extrabold text-[var(--on-surface)] tracking-tighter">{plan.precio}</span>
              {plan.periodo && <span class="text-lg text-[var(--on-surface-variant)] font-medium opacity-60">/{plan.periodo}</span>}
            </div>
          </div>

          <div class="flex-1 flex flex-col justify-between p-10 pt-0 mt-8">
            <ul class="space-y-5 mb-10">
              {plan.caracteristicas.map(feat => (
                <li class="flex items-start gap-3">
                  <div class="mt-1 bg-[var(--surface-container-low)] rounded-full p-1">
                    <Icon name="lucide:check" class="w-4 h-4 text-[var(--primary)] shrink-0" />
                  </div>
                  <span class="text-[var(--on-surface-variant)] font-medium">{feat}</span>
                </li>
              ))}
            </ul>

            <a 
              href={plan.cta.enlace}
              class={`${plan.destacado ? 'btn-primary' : 'btn-secondary'} w-full text-center py-4 px-6 rounded-xl font-bold transition-all hover:scale-[1.02] active:scale-95`}
            >
              {plan.cta.texto}
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
