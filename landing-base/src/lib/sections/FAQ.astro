---
import { Icon } from 'astro-icon/components';

interface Item {
  pregunta: string;
  respuesta: string;
}

interface Props {
  titulo: string;
  items: Item[];
}

const { titulo, items } = Astro.props;

if (!items || items.length === 0) return;
---

<section class="py-24 md:py-32 bg-[var(--surface-container-low)]" id="faq">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="section-title">{titulo}</h2>
    </div>

    <div class="max-w-3xl mx-auto space-y-4">
      {items.map((item, index) => (
        <details class="group bg-[var(--surface-container-lowest)] rounded-2xl shadow-[var(--shadow-ambient)] transition-all duration-500 overflow-hidden">
          <summary class="flex items-center justify-between cursor-pointer p-6 md:p-8 font-bold text-[var(--on-surface)] list-none text-xl tracking-tight">
            {item.pregunta}
            <span class="ml-6 flex-shrink-0 flex items-center justify-center w-10 h-10 rounded-2xl bg-[var(--surface-container-low)] text-[var(--primary)] group-open:bg-[var(--primary)] group-open:text-white transition-all duration-500 shadow-sm">
              <Icon name="lucide:chevron-down" class="w-6 h-6 transition-transform duration-500 group-open:-rotate-180" />
            </span>
          </summary>
          <div class="px-8 pb-8 text-[var(--on-surface-variant)] leading-relaxed text-lg group-open:animate-fadeIn font-medium">
            {item.respuesta}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  /* Ocultar el marcador nativo del details */
  details > summary::-webkit-details-marker {
    display: none;
  }
  
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  // Script opcional para cerrar los otros `<details>` (accordion behavior simple)
  const details = document.querySelectorAll('details');
  details.forEach((targetDetail) => {
    targetDetail.addEventListener('click', () => {
      details.forEach((detail) => {
        if (detail !== targetDetail) {
          detail.removeAttribute('open');
        }
      });
    });
  });
</script>
