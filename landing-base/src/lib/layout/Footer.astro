---
import { empresa } from "../data/empresa.js";
import { Icon } from 'astro-icon/components';

const year = new Date().getFullYear();
---
<footer class="bg-[var(--tertiary)] text-white/70 py-24 relative overflow-hidden">
  <div class="absolute inset-0 z-0 opacity-10">
    <div class="absolute top-0 right-0 w-1/2 h-full bg-white/5 blur-3xl rounded-full translate-x-1/3 -translate-y-1/2"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 md:grid-cols-4 lg:grid-cols-5 gap-12 lg:gap-8 relative z-10">
    
    <div class="md:col-span-1 lg:col-span-2">
      {empresa.logo ? (
        <img src={empresa.logo} alt={empresa.nombre} class="h-8 mb-4 object-contain brightness-0 invert opacity-80" />
      ) : (
        <h3 class="text-xl font-bold text-white mb-4">{empresa.nombre}</h3>
      )}
      <p class="text-sm text-gray-400 mb-4 max-w-sm">{empresa.descripcion}</p>
      
      <div class="flex gap-4">
        {empresa.redesSociales?.instagram && <a href={empresa.redesSociales.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="hover:text-white transition-colors"><Icon name="lucide:instagram" class="w-5 h-5"/></a>}
        {empresa.redesSociales?.facebook && <a href={empresa.redesSociales.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="hover:text-white transition-colors"><Icon name="lucide:facebook" class="w-5 h-5"/></a>}
        {empresa.redesSociales?.twitter && <a href={empresa.redesSociales.twitter} target="_blank" rel="noopener noreferrer" aria-label="Twitter" class="hover:text-white transition-colors"><Icon name="lucide:twitter" class="w-5 h-5"/></a>}
      </div>
    </div>
    
    <div>
      <h4 class="text-white font-bold mb-8 text-lg uppercase tracking-widest opacity-40 scale-75 origin-left">Contacto</h4>
      <ul class="space-y-4 text-base font-medium">
        {empresa.contacto?.telefono && <li class="flex items-center gap-4 hover:text-white transition-colors group"><div class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center group-hover:bg-[var(--primary)] transition-all"><Icon name="lucide:phone" class="w-4 h-4"/></div> {empresa.contacto.telefono}</li>}
        {empresa.contacto?.email && <li class="flex items-center gap-4 hover:text-white transition-colors group"><div class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center group-hover:bg-[var(--primary)] transition-all"><Icon name="lucide:mail" class="w-4 h-4"/></div> {empresa.contacto.email}</li>}
        {empresa.contacto?.direccion && <li class="flex items-start gap-4 hover:text-white transition-colors group"><div class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center group-hover:bg-[var(--primary)] transition-all mt-0.5"><Icon name="lucide:map-pin" class="w-4 h-4"/></div> <span class="max-w-[200px]">{empresa.contacto.direccion}</span></li>}
      </ul>
    </div>
    
    <div>
      <h4 class="text-white font-bold mb-8 text-lg uppercase tracking-widest opacity-40 scale-75 origin-left">Empresa</h4>
      <ul class="space-y-4 text-base font-medium flex flex-col">
        <a href="/" class="hover:text-white transition-colors w-fit">Inicio</a>
        <a href="#servicios" class="hover:text-white transition-colors w-fit">Servicios</a>
        <a href="#contacto" class="hover:text-white transition-colors w-fit">Contacto</a>
      </ul>
    </div>
    
  </div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-24 pt-8 border-t border-white/5 text-sm text-center text-white/30 font-bold uppercase tracking-widest scale-90">
    &copy; {year} {empresa.nombre} &bull; Hecho con Precisión Arquitectónica
  </div>
</footer>
