---
import { empresa } from "../data/empresa.js";
import { Icon } from 'astro-icon/components';
---
<nav class="fixed top-0 w-full z-50 h-16 md:h-20 glass border-b border-[rgba(198,198,205,0.15)] transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-full flex items-center justify-between">
    <a href="/" class="flex items-center gap-2">
      {empresa.logo ? (
        <img src={empresa.logo} alt={empresa.nombre} class="h-8 md:h-10 max-w-[160px] object-contain" />
      ) : (
        <span class="text-xl font-extrabold tracking-tighter text-[var(--on-surface)]">{empresa.nombre}</span>
      )}
    </a>
    <div class="hidden md:flex items-center gap-8">
      {empresa.servicios && empresa.servicios.length > 0 && <a href="#servicios" class="text-[var(--on-surface-variant)] hover:text-[var(--primary)] font-medium transition-colors">Servicios</a>}
      {empresa.sobreNosotros && empresa.sobreNosotros.texto && <a href="#nosotros" class="text-[var(--on-surface-variant)] hover:text-[var(--primary)] font-medium transition-colors">Nosotros</a>}
      <a href="#contacto" class="text-[var(--on-surface-variant)] hover:text-[var(--primary)] font-medium transition-colors">Contacto</a>
      
      {empresa.cta && (
        <a href={empresa.cta.enlace} class="btn-primary py-2 px-5 text-sm">
          {empresa.cta.texto}
        </a>
      )}
    </div>
    <button aria-label="Menú" class="md:hidden text-[var(--on-surface)]">
      <Icon name="lucide:menu" class="w-6 h-6" />
    </button>
  </div>
</nav>
