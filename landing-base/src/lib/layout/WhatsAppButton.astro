---
import { empresa } from "../data/empresa.js";
import { Icon } from 'astro-icon/components';

let link = "";
if (empresa.contacto?.whatsapp) {
  const phone = empresa.contacto.whatsapp.replace(/\D/g, "");
  const text = encodeURIComponent(`Hola, quisiera más información sobre ${empresa.nombre}`);
  link = `https://wa.me/${phone}?text=${text}`;
}
---

{empresa.contacto?.whatsapp && (
  <a 
    href={link}
    target="_blank" 
    rel="noopener noreferrer"
    aria-label="Contactar por WhatsApp"
    class="fixed bottom-8 right-8 z-40 flex items-center justify-center w-16 h-16 bg-[#25d366] text-white rounded-2xl shadow-2xl hover:scale-110 active:scale-95 transition-all hover:shadow-[0_20px_50px_rgba(37,211,102,0.3)]"
    style="animation: pulse 4s infinite;"
  >
    <Icon name="lucide:message-circle" class="w-8 h-8 font-bold" />
  </a>
)}

<style>
@keyframes pulse {
  0% { box-shadow: 0 0 0 0 rgba(37, 211, 102, 0.5); }
  70% { box-shadow: 0 0 0 15px rgba(37, 211, 102, 0); }
  100% { box-shadow: 0 0 0 0 rgba(37, 211, 102, 0); }
}
</style>
